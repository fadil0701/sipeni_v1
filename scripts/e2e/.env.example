# =============================================================================
# SI-MANTIK E2E — salin ke .env: cp .env.example .env
# Kredensial login di bawah (wajib). Harus cocok dengan akun di database Laravel.
# =============================================================================

# URL aplikasi (pastikan `composer run dev` atau `php artisan serve` aktif)
SIMANTIK_BASE_URL=http://127.0.0.1:8000

# Path root project Laravel (untuk bootstrap via artisan)
SIMANTIK_PROJECT_ROOT=../..

# Timeout HTTP (detik)
SIMANTIK_TIMEOUT=30

# Jeda antar login (detik) — hindari throttle Laravel. Smoke ~13 persona ≈ 3 menit.
SIMANTIK_LOGIN_DELAY=13

# Simpan laporan HTML ke folder ini (relatif ke scripts/e2e)
SIMANTIK_REPORT_DIR=reports

# Nonaktifkan verifikasi SSL (hanya dev lokal / staging self-signed)
SIMANTIK_INSECURE=true

# --- Browser automation (Playwright) ---
# false = jendela browser terlihat (demo / UAT)
SIMANTIK_BROWSER_HEADLESS=false
SIMANTIK_BROWSER_SLOW_MO=400
SIMANTIK_BROWSER_STEP_PAUSE=1.2

# =============================================================================
# Kredensial login — prioritas tertinggi (menggantikan personas.yaml / seeder)
# Isi sesuai akun nyata di environment target (staging/production UAT).
# =============================================================================

# Password umum (fallback jika pasangan role di bawah kosong)
SIMANTIK_PASSWORD_ADMIN=
SIMANTIK_PASSWORD_PEGAWAI=

# --- Administrator ---
SIMANTIK_EMAIL_SUPER_ADMIN=
SIMANTIK_PASSWORD_SUPER_ADMIN=

SIMANTIK_EMAIL_ADMIN_IT=
SIMANTIK_PASSWORD_ADMIN_IT=

# --- Alur transaksi (wajib untuk mode flow / browser) ---
SIMANTIK_EMAIL_PEMOHON=
SIMANTIK_PASSWORD_PEMOHON=

SIMANTIK_EMAIL_KEPALA_UNIT=
SIMANTIK_PASSWORD_KEPALA_UNIT=

SIMANTIK_EMAIL_KASUBBAG_TU=
SIMANTIK_PASSWORD_KASUBBAG_TU=

SIMANTIK_EMAIL_ADMIN_GUDANG=
SIMANTIK_PASSWORD_ADMIN_GUDANG=

# Kosongkan = sama dengan pemohon
SIMANTIK_EMAIL_PENERIMA=
SIMANTIK_PASSWORD_PENERIMA=

# --- Smoke test role tambahan (opsional) ---
SIMANTIK_EMAIL_KEPALA_PUSAT=
SIMANTIK_PASSWORD_KEPALA_PUSAT=

SIMANTIK_EMAIL_ADMIN_GUDANG_PERSEDIAAN=
SIMANTIK_PASSWORD_ADMIN_GUDANG_PERSEDIAAN=

SIMANTIK_EMAIL_ADMIN_GUDANG_ASET=
SIMANTIK_PASSWORD_ADMIN_GUDANG_ASET=

SIMANTIK_EMAIL_ADMIN_GUDANG_FARMASI=
SIMANTIK_PASSWORD_ADMIN_GUDANG_FARMASI=

SIMANTIK_EMAIL_PERENCANA=
SIMANTIK_PASSWORD_PERENCANA=

SIMANTIK_EMAIL_PENGADAAN=
SIMANTIK_PASSWORD_PENGADAAN=

SIMANTIK_EMAIL_KEUANGAN=
SIMANTIK_PASSWORD_KEUANGAN=

# =============================================================================
# Contoh dev lokal (setelah migrate:fresh --seed + ComprehensiveDummySeeder):
#
# SIMANTIK_PASSWORD_ADMIN=Admin@123
# SIMANTIK_PASSWORD_PEGAWAI=Pegawai@123
# SIMANTIK_EMAIL_SUPER_ADMIN=pusdatinppkp@gmail.com
# SIMANTIK_PASSWORD_SUPER_ADMIN=Admin@123
# SIMANTIK_EMAIL_ADMIN_IT=admin-it@sipeni.local
# SIMANTIK_PASSWORD_ADMIN_IT=Admin@123
# SIMANTIK_EMAIL_PEMOHON=staf-adm.gudang-unit@sipeni.local
# SIMANTIK_PASSWORD_PEMOHON=Pegawai@123
# SIMANTIK_EMAIL_KEPALA_UNIT=kepala-unit.3@sipeni.local
# SIMANTIK_PASSWORD_KEPALA_UNIT=Pegawai@123
# SIMANTIK_EMAIL_KASUBBAG_TU=kasubbag-tu.4@sipeni.local
# SIMANTIK_PASSWORD_KASUBBAG_TU=Pegawai@123
# SIMANTIK_EMAIL_ADMIN_GUDANG=staf-adm.gudang-pusat@sipeni.local
# SIMANTIK_PASSWORD_ADMIN_GUDANG=Pegawai@123
# =============================================================================
