APP_NAME="SI-MANTIK"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_SUBPATH=/demo-simantik
APP_URL=https://puspelkes.jakarta.go.id/demo-simantik
ASSET_URL=https://puspelkes.jakarta.go.id/demo-simantik
APP_USE_REQUEST_URL=false
SESSION_PATH=/demo-simantik/
SESSION_SECURE_COOKIE=true

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

APP_PORT=7001
VIEW_CLEAR_ON_BOOT=1

# Nginx container strip /demo-simantik — Laravel route tanpa prefix
APP_ROUTE_PREFIX=false

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=simantik
DB_USERNAME=simantik
DB_PASSWORD=GANTI_PASSWORD_DB_KUAT

MYSQL_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_KUAT

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_DOMAIN=
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@puspelkes.jakarta.go.id"
MAIL_FROM_NAME="${APP_NAME}"

TRUSTED_PROXIES=*

HTTP_PROXY=http://PROXY_HOST:PORT
HTTPS_PROXY=http://PROXY_HOST:PORT
NO_PROXY=localhost,127.0.0.1,mysql,.local,10.0.0.0/8

VITE_APP_NAME="${APP_NAME}"
QR_CODE_FORMAT=svg
OPENAI_API_KEY=

SIPENI_SUPER_ADMIN_NAME="Super Administrator"
SIPENI_SUPER_ADMIN_EMAIL=
SIPENI_SUPER_ADMIN_PASSWORD=

SIPENI_ADMIN_IT_NAME="Admin IT / Pengelola Aplikasi"
SIPENI_ADMIN_IT_EMAIL=
SIPENI_ADMIN_IT_PASSWORD=

SIPENI_SEED_DEMO_USERS=false
SIPENI_DEMO_PEGAWAI_PASSWORD=

FEATURE_PRINT_TEMPLATES=false
FEATURE_PEMAKAIAN_BARANG=false
RBAC_LEGACY_USER_MODULES_FALLBACK=false
SUPERADMIN_BYPASS_SCOPE=true

SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=false
# CDN layout: jQuery, Select2, html5-qrcode, fonts
SECURITY_CSP_POLICY="default-src 'self'; script-src 'self' 'unsafe-inline' https://code.jquery.com https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.bunny.net; font-src 'self' data: https://fonts.bunny.net; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
SECURITY_PERMISSIONS_POLICY="camera=(self), microphone=(), geolocation=()"
TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED_ROLES=super_administrator,admin
NOTIFICATIONS_MAIL_ENABLED=true
SIPENI_TOAST_MIRROR_FLASH=false
SIPENI_TOAST_DEFAULT_MS=4500

SBBK_KOP_BARIS1="PEMERINTAH PROVINSI DAERAH KHUSUS IBUKOTA"
SBBK_KOP_BARIS2="JAKARTA"
SBBK_KOP_BARIS3="DINAS KESEHATAN"
SBBK_KOP_BARIS4="PUSAT PELAYANAN KESEHATAN PEGAWAI"
SBBK_KOP_ALAMAT="JL. Medan Merdeka Selatan No. 8-9 Blok E Lantai 2, Jakarta Pusat"
SBBK_KOP_KOTA="JAKARTA PUSAT"
SBBK_KOP_LOGO_PATH="docs/Logo DKI.png"

SBBK_TTD_ADMIN_GUDANG_NAMA=
SBBK_TTD_ADMIN_GUDANG_NIP=
SBBK_TTD_MENGETAHUI_NAMA=
SBBK_TTD_MENGETAHUI_NIP=
SBBK_TTD_PENGURUS_BARANG_NAMA=
SBBK_TTD_PENGURUS_BARANG_NIP=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
