APP_NAME="SI-MANTIK"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_SUBPATH=
APP_URL=http://127.0.0.1:7001
ASSET_URL=http://127.0.0.1:7001
APP_USE_REQUEST_URL=true
SESSION_PATH=/
SESSION_SECURE_COOKIE=false

APP_PORT=7001
VIEW_CLEAR_ON_BOOT=1
APP_ROUTE_PREFIX=false

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=simantik
DB_USERNAME=simantik
DB_PASSWORD=secret

MYSQL_ROOT_PASSWORD=secret

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

TRUSTED_PROXIES=*

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,mysql,.local

FEATURE_PRINT_TEMPLATES=false
FEATURE_PEMAKAIAN_BARANG=false

# Kamera + GPS + QR (html5-qrcode CDN) — wajib geolocation=(self)
SECURITY_CSP_ENABLED=false
SECURITY_PERMISSIONS_POLICY="camera=(self), microphone=(), geolocation=(self)"
GEOCODE_SSL_VERIFY=true

TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED_ROLES=super_administrator,admin

SIPENI_SUPER_ADMIN_NAME="Super Administrator"
SIPENI_SUPER_ADMIN_EMAIL=
SIPENI_SUPER_ADMIN_PASSWORD=
SIPENI_ADMIN_IT_NAME="Admin IT"
SIPENI_ADMIN_IT_EMAIL=
SIPENI_ADMIN_IT_PASSWORD=
SUPERADMIN_BYPASS_SCOPE=true

# User demo alur transaksi (DemoUserSeeder) — matikan di production
SIPENI_SEED_DEMO_USERS=true
SIPENI_DEMO_PEGAWAI_PASSWORD=Demo@Sipeni2026!!
