APP_NAME="SI-MANTIK (Staging)"
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.example.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simantik_staging
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database
CACHE_STORE=database

# Aktifkan template cetak dinamis di staging
FEATURE_PRINT_TEMPLATES=true

# RBAC Fase 3
RBAC_LEGACY_USER_MODULES_FALLBACK=false

# Keamanan
SECURITY_CSP_ENABLED=true
SECURITY_CSP_REPORT_ONLY=true
TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED_ROLES=super_administrator,admin
NOTIFICATIONS_MAIL_ENABLED=false

# Proxy load balancer staging
# TRUSTED_PROXIES=10.0.0.1
