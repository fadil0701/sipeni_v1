APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: set APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Production: set SESSION_ENCRYPT=true and SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OpenAI (openai-php/client — AI SDK)
OPENAI_API_KEY=
# OPENAI_ORGANIZATION=

# SIPENI: template cetak admin + cetak SBBK dari template (true untuk mengaktifkan)
FEATURE_PRINT_TEMPLATES=false
FEATURE_PEMAKAIAN_BARANG=false

# SIPENI: cerminkan flash session ke toast (false = hanya banner di layout)
SIPENI_TOAST_MIRROR_FLASH=false
# SIPENI: durasi toast default (ms) saat mirror aktif
SIPENI_TOAST_DEFAULT_MS=4500

# RBAC Fase 3: matikan fallback user_modules (default false)
RBAC_LEGACY_USER_MODULES_FALLBACK=false

# Keamanan HTTP (CSP report-only default)
SECURITY_CSP_ENABLED=false
SECURITY_CSP_REPORT_ONLY=true

# Proxy tepercaya (production: IP load balancer, jangan *)
# TRUSTED_PROXIES=10.0.0.1

# Two-factor authentication
TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED_ROLES=super_administrator,admin

# Notifikasi email (butuh konfigurasi SMTP)
NOTIFICATIONS_MAIL_ENABLED=false

# =============================================================================
# Akun administrator & demo (AdminUserSeeder / PegawaiUserPerJabatanSeeder)
# =============================================================================
SIPENI_SUPER_ADMIN_NAME="Super Administrator"
SIPENI_SUPER_ADMIN_EMAIL=pusdatinppkp@gmail.com
SIPENI_SUPER_ADMIN_PASSWORD=Admin@12345678

SIPENI_ADMIN_IT_NAME="Admin IT / Pengelola Aplikasi"
SIPENI_ADMIN_IT_EMAIL=admin-it@sipeni.local
SIPENI_ADMIN_IT_PASSWORD=Admin@12345678

# User demo per jabatan (matikan di production: false)
SIPENI_SEED_DEMO_USERS=true
SIPENI_DEMO_PEGAWAI_PASSWORD=Pegawai@123456
# SIPENI_DEMO_EMAIL_PEMOHON=staf-adm.gudang-unit@sipeni.local
# SIPENI_DEMO_EMAIL_ADMIN_GUDANG=staf-adm.gudang-pusat@sipeni.local
# SIPENI_DEMO_EMAIL_PERENCANA=staf-adm.perencana@sipeni.local

# Subpath deployment (opsional)
# APP_ROUTE_PREFIX=auto

# Scope unit kerja — super_administrator bypass
SUPERADMIN_BYPASS_SCOPE=true

# QR code
QR_CODE_FORMAT=svg

# Kop surat SBBK (sesuaikan instansi)
# SBBK_KOP_BARIS1=
# SBBK_KOP_BARIS2=
# SBBK_KOP_BARIS3=
# SBBK_KOP_BARIS4=
# SBBK_KOP_ALAMAT=
# SBBK_KOP_KOTA=
# SBBK_KOP_LOGO_PATH=docs/Logo DKI.png
